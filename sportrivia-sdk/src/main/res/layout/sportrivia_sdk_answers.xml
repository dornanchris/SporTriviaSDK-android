<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#282D2F"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sportrivia_sdk_answers_title"
        android:textColor="@color/sportrivia_sdk_text"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp" />

    <!-- Team header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@android:color/white">

        <TextView
            android:id="@+id/sportrivia_sdk_text_team_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@android:color/black"
            android:textStyle="bold"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/sportrivia_sdk_image_team"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:scaleType="fitCenter" />
    </LinearLayout>

    <!-- Answers table -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/white">

        <TableLayout
            android:id="@+id/sportrivia_sdk_table_answers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="0" />
    </ScrollView>

    <!-- Back button -->
    <Button
        android:id="@+id/sportrivia_sdk_btn_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sportrivia_sdk_back"
        android:backgroundTint="@color/sportrivia_sdk_primary"
        android:textColor="@color/sportrivia_sdk_text"
        android:layout_gravity="center"
        android:layout_marginTop="16dp" />
</LinearLayout>
