<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/sportrivia_sdk_bg_gradient"
    android:padding="24dp"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sportrivia_sdk_player_info"
            android:textColor="@color/sportrivia_sdk_text"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/sportrivia_sdk_form_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sportrivia_sdk_loading_form"
            android:textColor="@color/sportrivia_sdk_text"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/sportrivia_sdk_form_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

        <EditText
            android:id="@+id/sportrivia_sdk_edit_first_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/sportrivia_sdk_first_name"
            android:inputType="textPersonName"
            android:padding="16dp"
            android:background="@drawable/sportrivia_sdk_field"
            android:textColor="@color/sportrivia_sdk_input_text"
            android:textColorHint="@color/sportrivia_sdk_input_hint"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/sportrivia_sdk_edit_last_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/sportrivia_sdk_last_name"
            android:inputType="textPersonName"
            android:padding="16dp"
            android:background="@drawable/sportrivia_sdk_field"
            android:textColor="@color/sportrivia_sdk_input_text"
            android:textColorHint="@color/sportrivia_sdk_input_hint"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/sportrivia_sdk_edit_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/sportrivia_sdk_email"
            android:inputType="textEmailAddress"
            android:padding="16dp"
            android:background="@drawable/sportrivia_sdk_field"
            android:textColor="@color/sportrivia_sdk_input_text"
            android:textColorHint="@color/sportrivia_sdk_input_hint"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/sportrivia_sdk_edit_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/sportrivia_sdk_phone"
            android:inputType="phone"
            android:padding="16dp"
            android:background="@drawable/sportrivia_sdk_field"
            android:textColor="@color/sportrivia_sdk_input_text"
            android:textColorHint="@color/sportrivia_sdk_input_hint"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/sportrivia_sdk_custom_fields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <CheckBox
            android:id="@+id/sportrivia_sdk_check_over18"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sportrivia_sdk_over18"
            android:textColor="@color/sportrivia_sdk_text"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <CheckBox
            android:id="@+id/sportrivia_sdk_check_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sportrivia_sdk_save_info"
            android:textColor="@color/sportrivia_sdk_text"
            android:layout_marginBottom="24dp" />

        </LinearLayout>

        <Button
            android:id="@+id/sportrivia_sdk_btn_submit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sportrivia_sdk_submit"
            android:backgroundTint="@color/sportrivia_sdk_primary"
            android:textColor="@color/sportrivia_sdk_text"
            android:enabled="false"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/sportrivia_sdk_btn_cancel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sportrivia_sdk_cancel"
            style="?android:attr/borderlessButtonStyle"
            android:textColor="@color/sportrivia_sdk_text" />
    </LinearLayout>
</ScrollView>
