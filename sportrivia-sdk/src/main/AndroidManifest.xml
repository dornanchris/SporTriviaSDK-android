<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Location for game-result uploads (best-effort; see PARTNER_SETUP.md).
         Host apps that must not request location can strip these with
         manifest-merger: <uses-permission android:name="..." tools:node="remove" /> -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <application>
        <activity
            android:name="com.sportrivia.sdk.internal.ui.UserInfoActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/SportriviaSDKTheme" />
        <activity
            android:name="com.sportrivia.sdk.internal.ui.CustomGameActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/SportriviaSDKTheme" />
        <activity
            android:name="com.sportrivia.sdk.internal.ui.GameOverActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/SportriviaSDKTheme" />
        <activity
            android:name="com.sportrivia.sdk.internal.ui.AnswersActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/SportriviaSDKTheme" />
    </application>
</manifest>
